# Firebase Admin SDK (descargar desde Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=   # Leer con reemplazo de \n literales por saltos de línea reales

# Firebase Web SDK (Project Settings > General > Your apps > Web app config)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=

# LLM provider: Mistral (obtener en https://console.mistral.ai/)
MISTRAL_API_KEY=
LLM_MODEL=mistral-large-latest

# Credenciales de usuarios de prueba (el script las crea con estos valores)
USER_VENTAS_EMAIL=ventas@laboratorio.local
USER_VENTAS_PASSWORD=Demo1234!
USER_COBRANZA_EMAIL=cobranza@laboratorio.local
USER_COBRANZA_PASSWORD=Demo1234!
USER_FINANZAS_EMAIL=finanzas@laboratorio.local
USER_FINANZAS_PASSWORD=Demo1234!
